### @name loginUser
POST http://localhost:4000/common-api/login
Content-Type: application/json

{
     "email":"user51@gmail.com",
     "password":"shiva"
}

### Store token
@token = {{loginUser.response.body.token}}

###logout
GET http://localhost:4000/common-api/logout


### Author Register
POST http://localhost:4000/author-api/users
Content-Type: application/json

{
     "firstName":"author4",
     "lastName":"author4",
     "email":"author4@gmail.com",
     "password":"shiva",
     "profileImageUrl":"http://example/dp1.png"
}

### author login
# @name loginAuthor
POST http://localhost:4000/common-api/login
Content-Type: application/json

{
     "email":"author4@gmail.com",
     "password":"shiva"
}

### Store author token
@authorToken = {{loginAuthor.response.body.token}}

### create artical
POST http://localhost:4000/author-api/article
Content-Type: application/json
Authorization: Bearer {{authorToken}}

{
     "title":"JAVA2",
     "category":"programming",
     "content":"thi is java  article"
}

### read artical by author
GET http://localhost:4000/author-api/articles
Authorization: Bearer {{authorToken}}

### read artical by user
GET http://localhost:4000/user-api/article/69b6e1067faf15e69e2f603d
Authorization: Bearer {{token}}

### update the artical
PUT http://localhost:4000/author-api/articles
Content-Type: application/json
Authorization: Bearer {{authorToken}}

{
     "articleId":"69c4ec4d36b35f8fa20e3300",
     "title":"Python",
     "category":"programming",
     "content":"updated content"
}
### soft delete the article

PATCH http://localhost:4000/author-api/articles/69c4ec4d36b35f8fa20e3300/status
Authorization: Bearer {{authorToken}}
Content-Type: application/json

{ 
     "isArticalActive": true
}


### get article by user
GET http://localhost:4000/user-api/articles

### add comment to article

PUT http://localhost:4000/user-api/articleComment 
Content-Type: application/json

{
     "articleId":"69c4ec4d36b35f8fa20e3300",
     "comment":"good"
}


